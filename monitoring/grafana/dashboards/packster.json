{
  "title": "Packster",
  "uid": "packster",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["packster"],
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "MongoDB",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "packster_mongo_up", "legendFormat": "MongoDB", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 3,
      "title": "Redis",
      "type": "stat",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "packster_redis_up", "legendFormat": "Redis", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 4,
      "title": "Auth Cache Hit Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] },
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "expr": "rate(packster_auth_cache_hits_total[5m]) / (rate(packster_auth_cache_hits_total[5m]) + rate(packster_auth_cache_misses_total[5m]))",
        "legendFormat": "Hit Rate",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 5,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [{
        "expr": "sum(rate(packster_http_requests_total[5m]))",
        "legendFormat": "req/s",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 6,
      "title": "Error Rate (5xx req/s)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "expr": "sum(rate(packster_http_requests_total{status=~\"5..\"}[5m]))",
        "legendFormat": "5xx/s",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 7,
      "title": "HTTP Traffic",
      "type": "row",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 8,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "sum by (method, path) (rate(packster_http_requests_total[5m]))",
        "legendFormat": "{{method}} {{path}}",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 9,
      "title": "Request Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(packster_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(packster_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(packster_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 10,
      "title": "HTTP Errors by Status",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "sum by (status) (rate(packster_http_requests_total{status=~\"[45]..\"}[5m]))",
        "legendFormat": "HTTP {{status}}",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 11,
      "title": "Auth Failures by Reason",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "sum by (reason) (rate(packster_auth_failures_total[5m]))",
        "legendFormat": "{{reason}}",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 12,
      "title": "Artifacts",
      "type": "row",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 13,
      "title": "Upload Rate by Product",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "sum by (product) (rate(packster_artifact_uploads_total{status=\"success\"}[5m]))",
        "legendFormat": "{{product}}",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 14,
      "title": "Download Rate by Product",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 23, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "sum by (product) (rate(packster_artifact_downloads_total[5m]))",
        "legendFormat": "{{product}}",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 15,
      "title": "Upload Throughput by Product",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 23, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "sum by (product) (rate(packster_artifact_upload_bytes_total[5m]))",
        "legendFormat": "{{product}}",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 16,
      "title": "Upload Errors by Product",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "sum by (product) (rate(packster_artifact_uploads_total{status=\"error\"}[5m]))",
        "legendFormat": "{{product}}",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 17,
      "title": "Auth Cache (hits vs misses)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "rate(packster_auth_cache_hits_total[5m])",
          "legendFormat": "hits",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "rate(packster_auth_cache_misses_total[5m])",
          "legendFormat": "misses",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false
      }
    ]
  }
}
